{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [],
  "title": "Pipeline Health",
  "description": "Data-reliability dashboard for the air-quality pipeline. Three questions: is it running & fresh, did it write everything (coverage), is the data sane (anomalies/drift). All timestamps are stored UTC and shown in Grafana's local/ICT time.",
  "tags": [
    "air-quality",
    "dataops"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Data Freshness",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now()-max(ts)))/60 AS \"min\" FROM device_readings WHERE resolution='instant'",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Minutes since the device's last instant reading. now()-max(ts)."
    },
    {
      "id": 2,
      "title": "Last Run Age",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now()-max(run_at)))/60 AS \"min\" FROM pipeline_run_log",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 45
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Minutes since the last fetch wrote a run-log row. Catches a stopped pipeline even when device data still looks fresh."
    },
    {
      "id": 3,
      "title": "Latest Coverage",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT covered AS \"buckets\" FROM pipeline_run_log ORDER BY run_at DESC LIMIT 1",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 6
              }
            ]
          },
          "max": 6
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Expected (endpoint,resolution) buckets written last run. 6 = full (device 4 + station 2)."
    },
    {
      "id": 4,
      "title": "Missing Buckets",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT COALESCE(NULLIF(array_to_string(missing, ', '), ''), 'none') AS \"missing\" FROM pipeline_run_log ORDER BY run_at DESC LIMIT 1",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/.*/"
        }
      },
      "description": "Which buckets were missing last run (e.g. device:daily). 'none' when coverage is full."
    },
    {
      "id": 5,
      "title": "Full-Coverage Ratio (7d)",
      "type": "gauge",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT count(*) FILTER (WHERE covered=expected)::real/NULLIF(count(*),0) AS \"ratio\" FROM pipeline_run_log WHERE run_at > now()-interval '7 days'",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Share of runs in the last 7 days that hit full coverage. Ratio of good runs, not an average."
    },
    {
      "id": 6,
      "title": "Coverage Over Time",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 18,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT run_at AS \"time\", covered FROM pipeline_run_log WHERE $__timeFilter(run_at) ORDER BY run_at",
          "format": "time_series",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 6
              }
            ]
          },
          "min": 0,
          "max": 6
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false
        }
      },
      "description": "covered per run. Dips below 6 mark a run where the API dropped a resolution."
    },
    {
      "id": 7,
      "title": "Anomalies (24h)",
      "type": "stat",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT count(*) AS \"anomalies\" FROM (SELECT ts FROM v_device_anomalies UNION ALL SELECT ts FROM v_station_anomalies) a WHERE ts > now()-interval '24 hours'",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Cross-field + range violations in the last 24h. Expected 0."
    },
    {
      "id": 8,
      "title": "Anomalies by Type (7d)",
      "type": "table",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 6,
        "y": 11,
        "w": 18,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT 'device' AS source, check_type, column_name, count(*) AS n FROM v_device_anomalies WHERE ts > now()-interval '7 days' GROUP BY check_type, column_name UNION ALL SELECT 'station', check_type, column_name, count(*) FROM v_station_anomalies WHERE ts > now()-interval '7 days' GROUP BY check_type, column_name ORDER BY n DESC",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "description": "What is wrong, grouped by check_type (cross_field|range) and column. Empty = clean."
    },
    {
      "id": 9,
      "title": "Column NULL Rate (24h, instant)",
      "type": "table",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRESQL}"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRESQL}"
          },
          "rawSql": "SELECT table_name, resolution, column_name, rows_recent, null_count, null_pct FROM v_column_health ORDER BY null_pct DESC, table_name, column_name",
          "format": "table",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "null_pct"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 0.1
                    }
                  ]
                }
              },
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      },
      "description": "Per-column NULL rate over 24h (instant only). A key column jumping above 0% signals API schema drift."
    }
  ]
}